# UISurf app backend configuration

APP_NAME="UISurf Agentic Platform"
APP_VERSION=0.1.0
API_PREFIX=/api/v1
DEBUG=false
HOST=0.0.0.0
PORT=8000
RELOAD=true
CORS_ORIGINS=["http://localhost:3000"]

# Firebase / Firestore configuration
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIRESTORE_DATABASE_ID=

# Google model configuration
GOOGLE_API_KEY=
PROMPT_REFINE_MODEL=gemini-2.5-flash

# ADK session configuration
CHAT_SESSION_APP_NAME=adkwebsurf
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_AI_AGENT_ENGINE_ID=

# UISurf admin integration
UI_AGENT_API_BASE_URL=http://127.0.0.1:8082/api
UI_AGENT_CONTROL_MODE=agent
UI_AGENT_TIMEOUT_SECONDS=15

# Live websocket model configuration
LIVE_AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
LIVE_AGENT_TEXT_MODEL=gemini-2.0-flash

# Logging
LOG_LEVEL=INFO
