# Environment variables for ADK Web Surf API
APP_NAME="UISurf Agentic Platform"
APP_VERSION=0.1.0
API_PREFIX=/api/v1
DEBUG=false
HOST=0.0.0.0
PORT=8000
RELOAD=true
CORS_ORIGINS=["http://localhost:3000"]

# Firebase auth settings
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIRESTORE_DATABASE_ID=
GOOGLE_API_KEY=

# Chat and prompt settings
CHAT_SESSION_APP_NAME=adkwebsurf
PROMPT_REFINE_MODEL=gemini-2.5-flash
UI_AGENT_API_BASE_URL=
UI_AGENT_CONTROL_MODE=agent
UI_AGENT_TIMEOUT_SECONDS=15

# Vertex AI session storage is enabled only when both values are set.
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_AI_AGENT_ENGINE_ID=
